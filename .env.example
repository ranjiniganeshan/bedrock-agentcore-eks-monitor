# ─────────────────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  deploy.sh will source it automatically.
#
#  .env is gitignored — never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# JIRA (optional — required for ImagePullBackOff / NodeNotReady escalation)
TF_VAR_jira_base_url=https://<your-org>.atlassian.net/
TF_VAR_jira_project_key=<PROJECT_KEY>
TF_VAR_jira_email=<your-email>
TF_VAR_jira_api_token=<your-jira-api-token>

# Slack (optional — required for escalation notifications)
TF_VAR_slack_webhook_url=https://hooks.slack.com/services/...
